#!/bin/bash
# =============================================================================
# setup_claude_code  —  build/refresh an isolated Claude Code VM on Intel macOS
# =============================================================================
# Run from your NORMAL admin account, WITHOUT sudo:   ./setup_claude_code
#
# Idempotent: edit claude-vm.conf, re-run, changes re-apply.
#   - Allowlist / proxy / pf / ports / shared dir : applied live.
#   - CPU / memory / disk : require 'limactl stop <name>' first (script tells you).
#
# Network enforcement:
#   - Squid on your Mac allows only listed domains (primary enforcer).
#   - socket_vmnet puts the VM on a kernel-visible bridge so pf can match
#     on the VM's source IPs (the backstop against raw-IP bypass).
#   - pf rules ONLY match traffic from the VM subnet; your Mac's traffic
#     is completely unaffected.
# =============================================================================

set -eo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONF="$SCRIPT_DIR/claude-vm.conf"
PROVISION="$SCRIPT_DIR/vm-provision.sh"
STATE_DIR="$HOME/.claude-vm"
mkdir -p "$STATE_DIR"

log()  { printf '\033[1;34m[setup]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[warn]\033[0m %s\n'  "$*"; }
die()  { printf '\033[1;31m[error]\033[0m %s\n' "$*" >&2; exit 1; }

[ "$(uname -s)" = "Darwin" ] || die "macOS only."
[ "$(id -u)" != "0" ]        || die "Do NOT run with sudo. Run as your normal admin user."
[ -f "$CONF" ]               || die "Config not found: $CONF"
[ -f "$PROVISION" ]          || die "Provisioner not found: $PROVISION"

# shellcheck disable=SC1090
. "$CONF"
[ -n "$VM_NAME" ] || die "VM_NAME empty in config."
PROXY_PORT="${PROXY_PORT:-3128}"

# Lima's socket_vmnet shared network — these are Lima's published defaults.
# If Lima ever changes them they'll also appear in ~/.lima/_config/networks.yaml.
LIMA_SHARED_SUBNET="192.168.105.0/24"
LIMA_SHARED_GW="192.168.105.1"

# ----------------------------------------------------------------------------
# 1. Homebrew, Lima, Squid
# ----------------------------------------------------------------------------
if ! command -v brew >/dev/null 2>&1; then
  log "Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  eval "$(/usr/local/bin/brew shellenv 2>/dev/null || true)"
fi
command -v brew    >/dev/null 2>&1 || die "Homebrew not on PATH. Open a new terminal and re-run."
command -v limactl           >/dev/null 2>&1 || { log "Installing Lima...";  brew install lima; }
command -v squid              >/dev/null 2>&1 || { log "Installing Squid..."; brew install squid; }
command -v qemu-system-x86_64 >/dev/null 2>&1 || { log "Installing QEMU...";  brew install qemu; }

# 1a. socket_vmnet — must be installed from SOURCE to /opt/socket_vmnet.
# ----------------------------------------------------------------------------
# The Lima project explicitly rejects Homebrew-installed socket_vmnet because
# Homebrew installs into a user-writable location, which fails Lima's security
# check. The documented and only supported method is a source build installed
# as root into /opt/socket_vmnet, so that every path component is root-owned
# and contains no symlinks.
# Reference: https://lima-vm.io/docs/config/network/vmnet/#socket_vmnet
SVMNET_PREFIX="/opt/socket_vmnet"
SVMNET_BIN="$SVMNET_PREFIX/bin/socket_vmnet"
SVMNET_VERSION="v1.2.2"   # update when new releases are available

if [ ! -f "$SVMNET_BIN" ]; then
  log "Installing socket_vmnet $SVMNET_VERSION from source to $SVMNET_PREFIX..."
  # Xcode Command Line Tools are required for make/clang.
  xcode-select -p >/dev/null 2>&1     || die "Xcode Command Line Tools not found. Run: xcode-select --install"
  BUILD_DIR="$(mktemp -d)"
  git clone --depth 1 --branch "$SVMNET_VERSION"     https://github.com/lima-vm/socket_vmnet "$BUILD_DIR/socket_vmnet"
  make -C "$BUILD_DIR/socket_vmnet"
  sudo make -C "$BUILD_DIR/socket_vmnet" PREFIX="$SVMNET_PREFIX" install.bin
  rm -rf "$BUILD_DIR"
  log "socket_vmnet installed to $SVMNET_BIN"
else
  log "socket_vmnet already installed at $SVMNET_BIN"
fi

# Write Lima's networks.yaml with the paths Lima expects.
# /private/var and /private/etc are required (not /var or /etc) because
# Lima rejects paths containing symlinks, and /var -> /private/var on macOS.
LIMA_CONFIG_DIR="$HOME/.lima/_config"
mkdir -p "$LIMA_CONFIG_DIR"
cat > "$LIMA_CONFIG_DIR/networks.yaml" <<NETCONF
# Lima networks.yaml — generated by setup_claude_code. Do not edit by hand.
paths:
  socketVMNet: /opt/socket_vmnet/bin/socket_vmnet
  varRun: /private/var/run/lima
  sudoers: /private/etc/sudoers.d/lima
group: everyone
networks:
  shared:
    mode: shared
    gateway: ${LIMA_SHARED_GW}
    dhcpEnd: 192.168.105.254
    netmask: 255.255.255.0
NETCONF
log "Lima networks.yaml written."

# Generate and install the sudoers file so Lima can start socket_vmnet
# without a password prompt. Uses sudo install -o root as Lima docs specify.
log "Installing Lima sudoers entry for socket_vmnet..."
SUDOERS_TMP="$(mktemp)"
limactl sudoers > "$SUDOERS_TMP"
# No -m flag: default mode 0755 is world-readable (Lima reads it as the
# current user) and has no write bits for group/others (sudo accepts it).
# All Lima and socket_vmnet docs use this exact form.
sudo install -o root "$SUDOERS_TMP" /etc/sudoers.d/lima
rm -f "$SUDOERS_TMP"
log "Lima sudoers installed."

# ----------------------------------------------------------------------------
# 2. Build the merged allowlist
# ----------------------------------------------------------------------------
ALLOWLIST="$STATE_DIR/allowed_domains.txt"
{
  printf '%s\n' "${PROTECTED_DOMAINS[@]}"
  printf '%s\n' "${ALLOWED_DOMAINS[@]}"
  [ -f "$STATE_DIR/proxy_domains.txt" ] && cat "$STATE_DIR/proxy_domains.txt" || true
} | sed '/^$/d' | sort -u > "$ALLOWLIST"
log "Allowlist: $(wc -l < "$ALLOWLIST" | tr -d ' ') domain rules."

# ----------------------------------------------------------------------------
# 3. Configure & (re)start Squid on the Mac
#    Squids listens on 0.0.0.0 so the VM can reach it at the Lima gateway IP.
# ----------------------------------------------------------------------------
log "Configuring Squid on the Mac (port ${PROXY_PORT})..."
SQUID_CONF="$STATE_DIR/squid.conf"
cat > "$SQUID_CONF" <<SQUID
http_port 0.0.0.0:${PROXY_PORT}
acl cc_allowed dstdomain "${ALLOWLIST}"
acl CONNECT method CONNECT
acl SSL_ports port 443
acl Safe_ports port 80
acl Safe_ports port 443
http_access deny !Safe_ports
http_access deny CONNECT !SSL_ports
http_access allow cc_allowed
http_access deny all
cache deny all
access_log stdio:${STATE_DIR}/squid-access.log
pid_filename ${STATE_DIR}/squid.pid
shutdown_lifetime 1 seconds
SQUID

sudo squid -k shutdown -f "$SQUID_CONF" 2>/dev/null || true
sleep 1
sudo squid -f "$SQUID_CONF" 2>/dev/null \
  || sudo squid -k reconfigure -f "$SQUID_CONF" 2>/dev/null || true
log "Squid running. Access log: ${STATE_DIR}/squid-access.log"

# ----------------------------------------------------------------------------
# 4. Generate the Lima YAML (with socket_vmnet shared networking)
# ----------------------------------------------------------------------------
LIMA_YAML="$STATE_DIR/${VM_NAME}.lima.yaml"
log "Writing Lima definition: $LIMA_YAML"
{
cat <<YAML
# Auto-generated from claude-vm.conf — edit the conf, not this file.
vmType: "qemu"  # qemu pairs with socket_vmnet; vz pairs with vzNAT
os: "Linux"
arch: "x86_64"
images:
  - location: "https://cloud-images.ubuntu.com/releases/24.04/release/ubuntu-24.04-server-cloudimg-amd64.img"
cpus: ${VM_CPUS}
memory: "${VM_MEMORY}"
disk: "${VM_DISK}"
mountType: "9p"  # virtiofs is vz-only; 9p is the qemu mountType
networks:
  - lima: shared
YAML
echo "mounts:"
echo "  - location: \"${SCRIPT_DIR}\""
echo "    mountPoint: \"/tmp/cc-setup\""
echo "    writable: false"
if [ -n "$SHARED_DIR" ]; then
  echo "  - location: \"${SHARED_DIR}\""
  echo "    mountPoint: \"/home/claude/shared\""
  echo "    writable: ${SHARED_WRITABLE}"
fi
echo "portForwards:"
for pf in "${FORWARD_PORTS[@]}"; do
  port="${pf%%:*}"; scope="${pf##*:}"
  if [ "$scope" = "network" ]; then hostip="0.0.0.0"; else hostip="127.0.0.1"; fi
  echo "  - guestPort: ${port}"
  echo "    hostPort: ${port}"
  echo "    hostIP: \"${hostip}\""
done
} > "$LIMA_YAML"

# ----------------------------------------------------------------------------
# 5. Create or start the VM
#    If the existing VM is using usernet (no socket_vmnet), it must be deleted
#    and recreated — Lima does not support changing network type on a live VM.
# ----------------------------------------------------------------------------
NEEDS_RECREATE="false"
if limactl list -q 2>/dev/null | grep -qx "$VM_NAME"; then
  # Recreate if not qemu. Lima pairs socket_vmnet with qemu, not vz.
  EXISTING_TYPE="$(limactl list --format '{{.VMType}}' "$VM_NAME" 2>/dev/null || true)"
  if [ "$EXISTING_TYPE" != "qemu" ]; then
    NEEDS_RECREATE="true"
  fi
fi

if [ "$NEEDS_RECREATE" = "true" ]; then
  warn "The existing VM uses vmType '${EXISTING_TYPE:-unknown}'. Lima docs pair"
  warn "socket_vmnet with qemu, not vz. VM must be recreated (Ubuntu is cached, ~1 min)."
  printf "\033[1;33m[warn]\033[0m Recreate the VM now? [y/N]: "; read -r CONFIRM
  if [ "$CONFIRM" = "y" ] || [ "$CONFIRM" = "Y" ]; then
    log "Stopping and deleting existing VM..."
    limactl stop "$VM_NAME" 2>/dev/null || true
    limactl delete "$VM_NAME"
    log "Creating VM with qemu + socket_vmnet (shared)..."
    limactl start --name="$VM_NAME" --tty=false "$LIMA_YAML"
  else
    warn "Skipped VM recreation. pf backstop will not be configured."
    warn "Squid (the primary enforcer) remains active."
    NEEDS_RECREATE="skipped"
  fi
elif limactl list -q 2>/dev/null | grep -qx "$VM_NAME"; then
  STATUS="$(limactl list --format '{{.Status}}' "$VM_NAME" 2>/dev/null || echo Unknown)"
  if [ "$STATUS" != "Running" ]; then
    log "Starting existing VM..."; limactl start "$VM_NAME"
  else
    log "VM already running."
    warn "CPU/mem/disk changes need: 'limactl stop $VM_NAME' then re-run."
  fi
else
  log "Creating VM (Ubuntu is cached after first run; ~1 minute)..."
  limactl start --name="$VM_NAME" --tty=false "$LIMA_YAML"
fi

# ----------------------------------------------------------------------------
# 6. pf backstop: block VM raw-IP egress via the socket_vmnet bridge interface
#
#    socket_vmnet puts the VM on a real kernel bridge. pf sees traffic FROM
#    the VM with source IPs in 192.168.105.0/24 BEFORE NAT, so we can match
#    and drop traffic that isn't heading to the proxy or Lima's DNS resolver.
#
#    Rules are written to /etc/pf.anchors/cc-vm and referenced from pf.conf.
#    Your Mac's own traffic (source: your Mac's IP) never matches these rules.
# ----------------------------------------------------------------------------
if [ "$NEEDS_RECREATE" != "skipped" ]; then
  log "Detecting Lima shared network bridge interface..."
  # Give socket_vmnet a moment to create the bridge after VM starts.
  sleep 3
  BRIDGE_IF="$(ifconfig 2>/dev/null \
    | grep -B5 "inet ${LIMA_SHARED_GW} " \
    | grep -E '^[a-z]' | tail -1 | cut -d: -f1 || true)"

  if [ -z "$BRIDGE_IF" ]; then
    warn "Could not detect Lima bridge interface automatically."
    warn "Look for the interface with 'inet ${LIMA_SHARED_GW}' in: ifconfig"
    warn "Then set it manually in the pf anchor: ${STATE_DIR}/pf-cc-vm.conf"
    warn "Squid remains the active enforcer in the meantime."
  else
    log "Lima bridge interface: ${BRIDGE_IF}  VM subnet: ${LIMA_SHARED_SUBNET}"

    # Write the pf anchor rules.
    PF_ANCHOR_FILE="$STATE_DIR/pf-cc-vm.conf"
    cat > "$PF_ANCHOR_FILE" <<PF
# cc-vm pf anchor — generated by setup_claude_code; do not edit by hand.
# Restricts outbound traffic from the VM subnet ${LIMA_SHARED_SUBNET}.
# Matches ONLY traffic from the VM subnet on the Lima bridge (${BRIDGE_IF}).
# Your Mac's own traffic is NEVER matched by these rules.

table <cc_vm_subnet> persist { ${LIMA_SHARED_SUBNET} }

# Allow traffic to Lima's DNS resolver (Lima resolves DNS for the VM).
pass in quick on ${BRIDGE_IF} proto { tcp udp } \
  from <cc_vm_subnet> to ${LIMA_SHARED_GW} port 53

# Allow VM to reach Squid on the Mac (the only permitted egress path).
pass in quick on ${BRIDGE_IF} proto tcp \
  from <cc_vm_subnet> to ${LIMA_SHARED_GW} port ${PROXY_PORT}

# Allow return traffic for already-established connections.
pass in quick on ${BRIDGE_IF} from <cc_vm_subnet> keep state

# Drop everything else from the VM subnet.
# This is the backstop: even raw-IP connections are blocked here.
block in quick on ${BRIDGE_IF} from <cc_vm_subnet> to any
PF

    # Install the anchor reference into /etc/pf.conf (idempotent).
    PF_CONF="/etc/pf.conf"
    PF_ANCHOR_REF='anchor "cc-vm"'
    PF_ANCHOR_LOAD="load anchor \"cc-vm\" from \"${PF_ANCHOR_FILE}\""
    if ! sudo grep -q "cc-vm" "$PF_CONF" 2>/dev/null; then
      log "Adding cc-vm anchor to $PF_CONF (backs up original first)..."
      sudo cp "$PF_CONF" "${PF_CONF}.before-ccvm"
      printf '\n# Claude Code VM sandbox anchor\n%s\n%s\n' \
        "$PF_ANCHOR_REF" "$PF_ANCHOR_LOAD" | sudo tee -a "$PF_CONF" >/dev/null
    else
      # Already present — refresh the anchor file it points to.
      sudo sed -i '' "s|load anchor \"cc-vm\" from .*|${PF_ANCHOR_LOAD}|" "$PF_CONF" 2>/dev/null || true
    fi

    # Enable pf and load the updated config.
    sudo pfctl -e 2>/dev/null || true
    if sudo pfctl -f "$PF_CONF" 2>/dev/null; then
      log "pf rules loaded. VM subnet ${LIMA_SHARED_SUBNET} is now default-deny."
      log "Verify: from inside the VM, 'curl https://api.anthropic.com' should work,"
      log "        and 'curl https://example.com' should be blocked."
    else
      warn "pfctl -f failed. Restoring original pf.conf..."
      sudo cp "${PF_CONF}.before-ccvm" "$PF_CONF" 2>/dev/null || true
      sudo pfctl -f "$PF_CONF" 2>/dev/null || true
      warn "pf rules NOT applied. Squid remains the active enforcer."
    fi

    # Persist across reboots via launchd.
    PF_LAUNCHD="$STATE_DIR/com.claudevm.pf.plist"
    cat > "$PF_LAUNCHD" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>            <string>com.claudevm.pf</string>
  <key>RunAtLoad</key>        <true/>
  <key>ProgramArguments</key>
  <array>
    <string>/sbin/pfctl</string>
    <string>-e</string>
  </array>
</dict>
</plist>
PLIST
    sudo cp "$PF_LAUNCHD" /Library/LaunchDaemons/com.claudevm.pf.plist
    sudo chown root:wheel /Library/LaunchDaemons/com.claudevm.pf.plist
    sudo chmod 644 /Library/LaunchDaemons/com.claudevm.pf.plist
    sudo launchctl load /Library/LaunchDaemons/com.claudevm.pf.plist 2>/dev/null || true
    log "pf enforcement persists across reboots."
  fi
fi

# ----------------------------------------------------------------------------
# 7. Push allowlist + provisioner into the VM and run it (idempotent)
# ----------------------------------------------------------------------------
log "Provisioning the VM (install + wiring). Runs every time; idempotent."
limactl shell --workdir /root "$VM_NAME" -- sudo tee /root/allowed_domains.txt >/dev/null < "$ALLOWLIST"
limactl shell --workdir /root "$VM_NAME" -- sudo tee /root/vm-provision.sh   >/dev/null < "$PROVISION"
limactl shell --workdir /root "$VM_NAME" -- sudo bash /root/vm-provision.sh \
  "PROXY_PORT=${PROXY_PORT}" \
  "INSTALL_NODE=${INSTALL_NODE}" \
  "INSTALL_PYTHON=${INSTALL_PYTHON}" \
  "INSTALL_DOCKER=${INSTALL_DOCKER}" \
  "INSTALL_GCLOUD=${INSTALL_GCLOUD}"

# ----------------------------------------------------------------------------
# 8. Install the 'ccvm' launcher + alias
# ----------------------------------------------------------------------------
LAUNCHER="$STATE_DIR/ccvm-launch.sh"
cat > "$LAUNCHER" <<LAUNCH
#!/bin/bash
set -eo pipefail
VM_NAME="${VM_NAME}"
STATE_DIR="${STATE_DIR}"
INDEX="\$STATE_DIR/credentials.index"

limactl list -q 2>/dev/null | grep -qx "\$VM_NAME" \
  || { echo "VM \$VM_NAME not found. Run ./setup_claude_code first."; exit 1; }
[ "\$(limactl list --format '{{.Status}}' "\$VM_NAME" 2>/dev/null)" = "Running" ] \
  || limactl start "\$VM_NAME"

ENV_ARGS=()
if [ -f "\$INDEX" ]; then
  while IFS= read -r line; do
    case "\$line" in ''|\#*) continue;; esac
    name="\$(echo "\$line" | awk '{print \$1}')"
    ctype="\$(echo "\$line" | awk '{print \$2}')"
    meta="\$(echo "\$line" | awk '{print \$3}')"
    [ "\$ctype" = "env" ] || continue
    val="\$(security find-generic-password -a "\$USER" -s "claude-vm-\$name" -w 2>/dev/null || true)"
    [ -n "\$val" ] || { echo "warn: no keychain value for '\$name'; skipping"; continue; }
    if [ "\$name" = "gcp" ]; then
      if [ -f "\$val" ]; then
        limactl shell --workdir /home/claude "\$VM_NAME" -- sudo -u claude mkdir -p /home/claude/.run-creds
        limactl shell --workdir /home/claude "\$VM_NAME" -- sudo -u claude tee /home/claude/.run-creds/gcp.json >/dev/null < "\$val"
        limactl shell --workdir /home/claude "\$VM_NAME" -- sudo -u claude chmod 600 /home/claude/.run-creds/gcp.json
        ENV_ARGS+=( "GOOGLE_APPLICATION_CREDENTIALS=/home/claude/.run-creds/gcp.json" )
      else
        echo "warn: gcp key path '\$val' not found on Mac; skipping"
      fi
    else
      ENV_ARGS+=( "\${meta}=\${val}" )
    fi
  done < "\$INDEX"
fi

if [ \${#ENV_ARGS[@]} -gt 0 ]; then
  exec limactl shell --workdir /home/claude "\$VM_NAME" -- sudo -iu claude env "\${ENV_ARGS[@]}" bash -l
else
  exec limactl shell --workdir /home/claude "\$VM_NAME" -- sudo -iu claude bash -l
fi
LAUNCH
chmod +x "$LAUNCHER"

ZSHRC="$HOME/.zshrc"; touch "$ZSHRC"
sed -i '' '/# >>> ccvm >>>/,/# <<< ccvm <<</d' "$ZSHRC" 2>/dev/null || true
cat >> "$ZSHRC" <<ALIAS
# >>> ccvm >>>
alias ccvm='$LAUNCHER'
# <<< ccvm <<<
ALIAS

cat <<EOF

$(printf '\033[1;32m[done]\033[0m') Environment ready.

  Open a NEW terminal (to pick up the alias), then:

    ccvm          — enter the VM as the 'claude' user
    claude        — start Claude Code (first time: run /login once)

  Verify network enforcement from inside the VM:
    curl -s -o /dev/null -w "%{http_code}\\n" https://api.anthropic.com   # expect 401/403
    curl -s -o /dev/null -w "%{http_code}\\n" https://example.com          # expect 000/blocked

  Watch the Squid log (live):
    tail -f ~/.claude-vm/squid-access.log

  Add credentials any time:   ./manage_credentials add github
  Change config:              edit claude-vm.conf, re-run ./setup_claude_code
  Stop the VM:                limactl stop ${VM_NAME}
  Delete + rebuild:           limactl delete ${VM_NAME} && ./setup_claude_code

  To REMOVE the pf rules:
    sudo pfctl -a cc-vm -F all
    sudo sed -i '' '/cc-vm/d' /etc/pf.conf
    sudo launchctl unload /Library/LaunchDaemons/com.claudevm.pf.plist
    sudo rm /Library/LaunchDaemons/com.claudevm.pf.plist

EOF
