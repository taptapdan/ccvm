#!/bin/bash
# =============================================================================
# manage_credentials  —  store/list/remove credentials in the macOS keychain
# =============================================================================
# Usage:
#   ./manage_credentials add <name> [--type=env|--type=proxy]
#   ./manage_credentials remove <name>
#   ./manage_credentials list
#
# Values live ONLY in the macOS keychain (encrypted at rest, unlocked at login).
# This script writes NO secret values to disk. A small index file records the
# STRUCTURE only (name, type, env-var-name or proxy-domain) — never values.
# =============================================================================

set -eo pipefail
STATE_DIR="$HOME/.claude-vm"; mkdir -p "$STATE_DIR"
INDEX="$STATE_DIR/credentials.index"
PROXY_DOMAINS="$STATE_DIR/proxy_domains.txt"
touch "$INDEX" "$PROXY_DOMAINS"

die() { printf '\033[1;31m[error]\033[0m %s\n' "$*" >&2; exit 1; }
[ "$(uname -s)" = "Darwin" ] || die "macOS only (uses the system keychain)."

# Built-in defaults: name -> "type env_or_domain"
builtin_default() {
  case "$1" in
    anthropic) echo "env ANTHROPIC_API_KEY" ;;   # Console/API billing; Pro/Max use /login instead
    github)    echo "env GITHUB_TOKEN" ;;
    gcp)       echo "env GOOGLE_APPLICATION_CREDENTIALS" ;;
    openai)    echo "proxy api.openai.com" ;;
    *)         echo "" ;;
  esac
}

index_remove() { grep -v -E "^[[:space:]]*$1[[:space:]]" "$INDEX" > "$INDEX.tmp" 2>/dev/null || true; mv "$INDEX.tmp" "$INDEX"; }
index_get()    { grep -E "^[[:space:]]*$1[[:space:]]" "$INDEX" 2>/dev/null | head -1; }

rebuild_proxy_domains() {
  : > "$PROXY_DOMAINS"
  while IFS= read -r line; do
    case "$line" in ''|\#*) continue;; esac
    t="$(echo "$line" | awk '{print $2}')"; m="$(echo "$line" | awk '{print $3}')"
    [ "$t" = "proxy" ] && echo "$m" >> "$PROXY_DOMAINS"
  done < "$INDEX"
}

cmd_add() {
  name="$1"; shift || true
  [ -n "$name" ] || die "Usage: manage_credentials add <name> [--type=env|--type=proxy]"
  ctype=""; for a in "$@"; do case "$a" in --type=*) ctype="${a#--type=}";; esac; done

  def="$(builtin_default "$name")"; def_type="$(echo "$def" | awk '{print $1}')"; def_meta="$(echo "$def" | awk '{print $2}')"
  [ -z "$ctype" ] && ctype="$def_type"
  if [ -z "$ctype" ]; then
    echo "How should '$name' be used?"
    echo "  1) env    — injected as an environment variable into the VM session"
    echo "  2) proxy  — kept on your Mac; Squid injects it into HTTPS requests"
    echo "             (NOTE: proxy injection requires scoped TLS interception;"
    echo "              see CREDENTIALS.md. env is the simpler, default choice.)"
    printf "Enter 1 or 2: "; read -r c
    case "$c" in 1) ctype="env";; 2) ctype="proxy";; *) die "Invalid choice.";; esac
  fi

  meta="$def_meta"
  if [ "$ctype" = "env" ] && [ -z "$meta" ]; then
    if [ "$name" = "gcp" ]; then meta="GOOGLE_APPLICATION_CREDENTIALS"; else
      printf "Environment variable name to set inside the VM (e.g. MYSVC_API_KEY): "; read -r meta
    fi
  elif [ "$ctype" = "proxy" ] && [ -z "$meta" ]; then
    printf "Domain to inject this credential for (e.g. api.example.com): "; read -r meta
  fi
  [ -n "$meta" ] || die "Missing env-var name / domain."

  # Read the secret value (or, for gcp, a path to the JSON key file).
  if [ "$name" = "gcp" ]; then
    printf "Path on your Mac to the GCP service-account JSON key file: "; read -r val
    [ -f "$val" ] || die "File not found: $val"
  else
    printf "Paste the secret value for '%s' (input hidden): " "$name"; read -rs val; echo
    [ -n "$val" ] || die "Empty value."
  fi

  # Store in keychain (overwrite if present).
  security delete-generic-password -a "$USER" -s "claude-vm-$name" >/dev/null 2>&1 || true
  security add-generic-password -a "$USER" -s "claude-vm-$name" -w "$val" >/dev/null
  index_remove "$name"
  printf '%-12s %-6s %s\n' "$name" "$ctype" "$meta" >> "$INDEX"
  rebuild_proxy_domains

  echo "Stored '$name' ($ctype -> $meta) in the keychain."
  [ "$ctype" = "proxy" ] && echo "Re-run ./setup_claude_code so Squid picks up the new domain."
  [ "$ctype" = "env" ]   && echo "Available next time you run 'ccvm'."
}

cmd_remove() {
  name="$1"; [ -n "$name" ] || die "Usage: manage_credentials remove <name>"
  security delete-generic-password -a "$USER" -s "claude-vm-$name" >/dev/null 2>&1 || true
  index_remove "$name"; rebuild_proxy_domains
  echo "Removed '$name'."
}

cmd_list() {
  if [ ! -s "$INDEX" ]; then echo "No credentials stored."; return; fi
  printf '%-12s %-6s %s\n' "NAME" "TYPE" "ENV-VAR / DOMAIN"
  printf '%-12s %-6s %s\n' "----" "----" "----------------"
  while IFS= read -r line; do
    case "$line" in ''|\#*) continue;; esac
    n="$(echo "$line" | awk '{print $1}')"; t="$(echo "$line" | awk '{print $2}')"; m="$(echo "$line" | awk '{print $3}')"
    have="missing"; security find-generic-password -a "$USER" -s "claude-vm-$n" -w >/dev/null 2>&1 && have="stored"
    printf '%-12s %-6s %-28s [%s]\n' "$n" "$t" "$m" "$have"
  done < "$INDEX"
}

sub="${1:-}"; shift || true
case "$sub" in
  add)    cmd_add "$@" ;;
  remove) cmd_remove "$@" ;;
  list)   cmd_list ;;
  *) echo "Usage: manage_credentials {add|remove|list} ..."; exit 1 ;;
esac
